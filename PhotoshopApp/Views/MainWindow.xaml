<Window x:Class="PhotoshopApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:PhotoshopApp.UI.ViewModels"
        xmlns:controls="clr-namespace:PhotoshopApp.UI.Controls"
        Title="Photoshop Clone" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    
    <Window.DataContext>
        <vm:MainViewModel x:Name="ViewModel"/>
    </Window.DataContext>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Menu Bar -->
            <RowDefinition Height="Auto"/> <!-- Tool Bar -->
            <RowDefinition Height="*"/>    <!-- Main Content -->
            <RowDefinition Height="Auto"/> <!-- Status Bar -->
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <Menu Grid.Row="0" Background="#F0F0F0">
            <MenuItem Header="_File">
                <MenuItem Header="_Open" Command="{Binding OpenImageCommand}" InputGestureText="Ctrl+O"/>
                <MenuItem Header="_Save" Command="{Binding SaveImageCommand}" InputGestureText="Ctrl+S"/>
                <Separator/>
                <MenuItem Header="_Exit" />
            </MenuItem>
            <MenuItem Header="_Edit">
                <MenuItem Header="_Undo" Command="{Binding UndoCommand}" InputGestureText="Ctrl+Z"/>
                <MenuItem Header="_Redo" Command="{Binding RedoCommand}" InputGestureText="Ctrl+Y"/>
            </MenuItem>
            <MenuItem Header="_Image">
                <MenuItem Header="_Rotate">
                    <MenuItem Header="90° Clockwise" Command="{Binding Rotate90Command}"/>
                    <MenuItem Header="180°" Command="{Binding Rotate180Command}"/>
                    <MenuItem Header="90° Counter-Clockwise" Command="{Binding Rotate270Command}"/>
                </MenuItem>
                <MenuItem Header="_Flip">
                    <MenuItem Header="Horizontal" Command="{Binding FlipHorizontalCommand}"/>
                    <MenuItem Header="Vertical" Command="{Binding FlipVerticalCommand}"/>
                </MenuItem>
                <MenuItem Header="_Resize"/>
                <MenuItem Header="_Crop"/>
            </MenuItem>
            <MenuItem Header="_Filter">
                <MenuItem Header="_Blur"/>
                <MenuItem Header="_Sharpen"/>
                <MenuItem Header="_Adjustments"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About"/>
            </MenuItem>
        </Menu>

        <!-- Tool Bar -->
        <ToolBar Grid.Row="1" Background="#E8E8E8" Padding="5">
            <Button Content="📁 Open" Command="{Binding OpenImageCommand}" Width="80" Margin="0,0,5,0"/>
            <Button Content="💾 Save" Command="{Binding SaveImageCommand}" Width="80" Margin="0,0,5,0"/>
            <Separator/>
            <Button Content="↩️ Undo" Command="{Binding UndoCommand}" Width="80" Margin="0,0,5,0"/>
            <Button Content="↪️ Redo" Command="{Binding RedoCommand}" Width="80" Margin="0,0,5,0"/>
        </ToolBar>

        <!-- Main Content -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/> <!-- Left Panel -->
                <ColumnDefinition Width="*"/>   <!-- Canvas Area -->
                <ColumnDefinition Width="250"/> <!-- Right Panel -->
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Tools -->
            <Border Grid.Column="0" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="0,0,1,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Tools" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                    
                    <!-- Tool Buttons -->
                    <Button Content="🖱️ Move" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    <Button Content="✂️ Crop" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    <Button Content="🖌️ Brush" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    <Button Content="🧽 Eraser" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    <Button Content="🔲 Rectangle" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    <Button Content="⭕ Circle" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    <Button Content="✏️ Text" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    <Button Content="🪣 Fill" Width="220" Height="30" Margin="0,5" HorizontalAlignment="Left"/>
                    
                    <Separator Margin="0,15,0,15"/>
                    
                    <TextBlock Text="Properties" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                    <!-- Tool properties will be added here -->
                </StackPanel>
            </Border>

            <!-- Canvas Area -->
            <Border Grid.Column="1" Background="#333333">
                <Grid>
                    <controls:ImageCanvas x:Name="ImageCanvasControl"/>
                </Grid>
            </Border>

            <!-- Right Panel - Layers -->
            <Border Grid.Column="2" Background="#F5F5F5" BorderBrush="#CCCCCC" BorderThickness="1,0,0,0" Padding="10">
                <StackPanel>
                    <TextBlock Text="Layers" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                    
                    <!-- Layer controls -->
                    <Button Content="+ Add Layer" Width="100" Height="30" Margin="0,5" HorizontalAlignment="Left" 
                            Command="{Binding AddLayerCommand}"/>
                    <Button Content="- Delete Layer" Width="100" Height="30" Margin="5,5,0,5" HorizontalAlignment="Left" 
                            Command="{Binding DeleteLayerCommand}"/>
                    <Button Content="↑ Move Up" Width="100" Height="30" Margin="0,5" HorizontalAlignment="Left" 
                            Command="{Binding MoveLayerUpCommand}"/>
                    <Button Content="↓ Move Down" Width="100" Height="30" Margin="5,5,0,5" HorizontalAlignment="Left" 
                            Command="{Binding MoveLayerDownCommand}"/>
                    
                    <Separator Margin="0,15,0,15"/>
                    
<!-- Layers list -->
                    <Border Background="White" 
                            BorderBrush="#CCCCCC" 
                            BorderThickness="1" 
                            Height="300"
                            Width="220">
                        <ListBox ItemsSource="{Binding Layers}" 
                                 Background="Transparent"
                                 BorderThickness="0"
                                 SelectedItem="{Binding ActiveLayer, Mode=OneWayToSource}"
                                 SelectionMode="Extended">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                            <Setter Property="Background" Value="#E3F2FD"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource LayerItemBorder}" 
                                            Background="{Binding IsActive, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <Grid Margin="4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="32"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <!-- Visibility Toggle -->
                                            <CheckBox Grid.Column="0" 
                                                      IsChecked="{Binding IsVisible}" 
                                                      VerticalAlignment="Center"
                                                      Margin="0,0,4,0"
                                                      Command="{Binding ToggleVisibilityCommand}"/>
                                            
                                            <!-- Thumbnail -->
                                            <Border Grid.Column="1" 
                                                    Width="32" Height="32" 
                                                    Background="#EEEEEE" 
                                                    BorderBrush="#CCCCCC" 
                                                    BorderThickness="1"
                                                    Margin="0,0,8,0">
                                                <Image Source="{Binding Thumbnail}"
                                                       Stretch="Uniform"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
                                            
                                            <!-- Layer Name -->
                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding Name}" 
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Left"
                                                       FontSize="12"
                                                       Foreground="#333333"
                                                       TextTrimming="CharacterEllipsis"/>
                                            
                                            <!-- Lock Indicator -->
                                            <TextBlock Grid.Column="3" 
                                                       Text="🔒" 
                                                       FontSize="12"
                                                       Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibilityConverter}}"
                                                       VerticalAlignment="Center"
                                                       Margin="4,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                    
                    <Separator Margin="0,15,0,15"/>
                    
                    <TextBlock Text="Layer Properties" FontWeight="Bold" Margin="0,0,0,10" FontSize="14"/>
                    
                    <!-- Layer Opacity -->
                    <TextBlock Text="Opacity:" Margin="0,5"/>
                    <Slider x:Name="OpacitySlider" Minimum="0" Maximum="100" Value="100" 
                            Width="220" TickFrequency="1" IsSnapToTickEnabled="False"
                            ValueChanged="OpacitySlider_ValueChanged"/>
                    <TextBlock x:Name="OpacityValueText" Text="100%" HorizontalAlignment="Right" Margin="0,-20,0,20"/>
                    
                    <!-- Blend Mode -->
                    <TextBlock Text="Blend Mode:" Margin="0,5"/>
                    <ComboBox x:Name="BlendModeComboBox" Width="220" Height="25" Margin="0,5" 
                              SelectionChanged="BlendModeComboBox_SelectionChanged"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <StatusBar Grid.Row="3" Background="#E8E8E8">
            <StatusBarItem>
                <TextBlock Text="Ready"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ImagePath}"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding ImageInfo}"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="Zoom: 100%"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>