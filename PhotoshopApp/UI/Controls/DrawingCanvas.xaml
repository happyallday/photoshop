<UserControl x:Class="PhotoshopApp.UI.Controls.DrawingCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="#333333">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Canvas toolbar -->
        <Border Grid.Row="0" Background="#444444" Padding="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Status: " Foreground="LightGray" VerticalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                <Separator Margin="10,0" Background="#666666"/>
                <TextBlock Text="Position: " Foreground="LightGray" VerticalAlignment="Center"/>
                <TextBlock x:Name="PositionText" Text="0, 0" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
                <Separator Margin="10,0" Background="#666666"/>
                <TextBlock Text="Zoom: " Foreground="LightGray" VerticalAlignment="Center"/>
                <TextBlock x:Name="ZoomText" Text="100%" Foreground="White" VerticalAlignment="Center" Margin="5,0"/>
            </StackPanel>
        </Border>
        
        <!-- Drawing canvas area -->
        <Grid Grid.Row="1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" 
                          x:Name="CanvasScrollViewer">
                <Grid x:Name="CanvasGrid" Background="#555555">
                    <!-- Main drawing image -->
                    <Image x:Name="MainDrawingImage"
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           UseLayoutRounding="True"
                           MouseLeftButtonDown="DrawingImage_MouseLeftButtonDown"
                           MouseLeftButtonUp="DrawingImage_MouseLeftButtonUp"
                           MouseMove="DrawingImage_MouseMove"
                           MouseRightButtonDown="DrawingImage_MouseRightButtonDown"/>
                    
                    <!-- Preview layer -->
                    <Image x:Name="PreviewImage"
                           Stretch="None"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           UseLayoutRounding="True"
                           IsHitTestVisible="False"/>
                    
                    <!-- Selection overlay -->
                    <Canvas x:Name="SelectionOverlay" IsHitTestVisible="False">
                        <Rectangle x:Name="SelectionRectangle" 
                                  Stroke="White" StrokeThickness="1" 
                                  StrokeDashArray="4,2" 
                                  Fill="#40000000"
                                  Visibility="Collapsed"/>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>