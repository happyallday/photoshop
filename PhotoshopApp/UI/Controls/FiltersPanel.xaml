<UserControl x:Class="PhotoshopApp.UI.Controls.FiltersPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             d:DesignHeight="400" d:DesignWidth="280">
    <Border Background="White" BorderBrush="#CCCCCC" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            
            <!-- Header -->
            <Border Grid.Row="0" Background="#F8F8F8" Padding="10,5">
                <TextBlock Text="Filters" FontWeight="Bold" FontSize="14"/>
            </Border>
            
            <!-- Filter Preview -->
            <Border Grid.Row="1" Background="#FAFAFA" Padding="10" BorderBrush="#EEEEEE" BorderThickness="0,0,1,0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Preview:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <Border Width="120" Height="80" Background="#CCCCCC">
                        <Image Source="{Binding FilterPreview}" Stretch="Uniform" 
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                    </Border>
                </StackPanel>
            </Border>
            
            <!-- Filter List -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding FilterCategories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Header="{Binding Name}" IsExpanded="{Binding IsExpanded}" 
                                      Background="White" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                                <ItemsControl ItemsSource="{Binding Filters}" Margin="5">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}" 
                                                    Command="{Binding Command}"
                                                    HorizontalContentAlignment="Left"
                                                    Padding="10,5"
                                                    Background="Transparent"
                                                    BorderThickness="0"
                                                    ToolTip="{Binding Description}">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Property="Background" Value="#E8F4FD"/>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="Background" Value="#0078D7"/>
                                                                <Setter Property="Foreground" Value="White"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            
            <!-- Action Buttons -->
            <Border Grid.Row="3" Background="#F8F8F8" Padding="10,5" BorderBrush="#EEEEEE" BorderThickness="1,0,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="Apply Filter" Width="100" Height="25" Margin="5,0"
                            Command="{Binding ApplyFilterCommand}"
                            CommandParameter="{Binding}"/>
                    <Button Content="Reset" Width="100" Height="25" Margin="5,0"
                            Command="{Binding ResetFiltersCommand}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>